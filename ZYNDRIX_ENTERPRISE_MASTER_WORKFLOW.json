              "role": "user",
              "content": "Nombre: {{ $('normalize_data').first().json.lead_name }}\nEmpresa: {{ $('normalize_data').first().json.company_name }}\nServicio: {{ $('normalize_data').first().json.service_type }}\nMensaje: {{ $('normalize_data').first().json.message }}\nFuente: {{ $('normalize_data').first().json.source }}\n\nGenera un análisis profesional y JSON válido."
            }
