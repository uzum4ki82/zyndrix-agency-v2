      "main": [
        [{"node": "\uD83D\uDCDD Extract Message", "type": "main", "index": 0}],
        [{"node": "\uD83D\uDCDD Extract Message", "type": "main", "index": 0}],
        [{"node": "\uD83D\uDEAB Ignore Type",    "type": "main", "index": 0}]
      ]
    },
    "\uD83D\uDCDD Extract Message": {
      "main": [[{"node": "\uD83E\uDD16 Zyn AI Agent", "type": "main", "index": 0}]]
    },
    "\uD83E\uDD16 Zyn AI Agent": {
      "main": [[{"node": "\u2705 Prepare Response", "type": "main", "index": 0}]]
    },
    "\u2705 Prepare Response": {
      "main": [[{"node": "\uD83D\uDCE4 Send WA Message", "type": "main", "index": 0}]]
    },
    "\uD83D\uDCE4 Send WA Message": {
      "main": [[{"node": "\u2714\uFE0F Webhook 200 OK", "type": "main", "index": 0}]]
    },
    "\uD83E\uDDE0 GPT-4o Model": {
      "ai_languageModel": [[{"node": "\uD83E\uDD16 Zyn AI Agent", "type": "ai_languageModel", "index": 0}]]
    },
    "\uD83D\uDDC4\uFE0F Postgres Memory": {
      "ai_memory": [[{"node": "\uD83E\uDD16 Zyn AI Agent", "type": "ai_memory", "index": 0}]]
    },
    "\uD83D\uDCC5 Calendar Tool": {
      "ai_tool": [[{"node": "\uD83E\uDD16 Zyn AI Agent", "type": "ai_tool", "index": 0}]]
    },
    "\uD83D\uDCE7 Gmail Tool": {
      "ai_tool": [[{"node": "\uD83E\uDD16 Zyn AI Agent", "type": "ai_tool", "index": 1}]]
    },
    "\u26A0\uFE0F Error Trigger": {
      "main": [[{"node": "\uD83D\uDEA8 Alert Admin", "type": "main", "index": 0}]]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  }
}